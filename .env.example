# NOTE: keep comments on their own lines — `docker run --env-file` does not
# strip inline comments and would glue them onto the value.

# --- Stage 2: LLM evaluation (any OpenAI-compatible server: vLLM, Ollama...) ---
# Your GPU host (Ollama, OpenAI-compatible API)
VLLM_BASE_URL=http://172.20.7.22:11434
VLLM_MODEL=gemma4:31b
VLLM_API_KEY=EMPTY

# --- Stage 1: embeddings for semantic resume scoring ---
# Default: runs EMBEDDING_MODEL in-process with sentence-transformers (on-prem,
# no data leaves the machine). To use a remote OpenAI-compatible endpoint
# instead, set EMBEDDING_BASE_URL (+ EMBEDDING_API_KEY if needed) and an
# endpoint model name, e.g. text-embedding-3-large.
EMBEDDING_MODEL=all-MiniLM-L6-v2
#EMBEDDING_BASE_URL=
#EMBEDDING_API_KEY=

# --- Pipeline tuning ---
# How many similarity-shortlisted resumes go to the LLM
TOP_K=20
# Parallel LLM evaluation calls
MAX_CONCURRENT_EVALS=12
# Resumes scored per LLM call (a failed batch falls back to one call per resume)
BATCH_EVAL_SIZE=4
# Truncation limit for each resume/JD sent to the models
MAX_DOC_CHARS=10000
# Larger budget for the JD requirements extraction (fits several JD files)
MAX_JD_CHARS=20000

# --- Upload / memory guards ---
# Max resumes accepted per screening (a clear 413 is returned above this)
MAX_RESUMES=100
# Per-file size cap in MB; larger files are skipped and reported
MAX_FILE_MB=10
# In-memory runs retained before the oldest is evicted
MAX_RETAINED_RUNS=50

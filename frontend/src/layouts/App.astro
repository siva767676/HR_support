---
import "@/styles/global.css";
import MobileNav from "@/components/app/MobileNav";

interface Props {
  title?: string;
  description?: string;
  active?: "jd" | "screening" | "interview" | "dashboard" | "";
}
const { title = "MEDHA", description = "", active = "" } = Astro.props;

const links = [
  { key: "dashboard", label: "Dashboard", href: "/dashboard" },
  { key: "jd", label: "JD Generation", href: "/jd" },
  { key: "screening", label: "CV Analyzer", href: "/screening" },
  { key: "interview", label: "AI Interview", href: "/interview" },
];

// Lucide icon paths, inlined for the static Astro sidebar. The mobile drawer island
// maps the same keys to lucide-react components.
const icons: Record<string, string> = {
  dashboard: '<rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/>',
  jd: '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>',
  screening: '<path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><circle cx="12" cy="12" r="3"/><path d="m16 16-1.9-1.9"/>',
  interview: '<path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/>',
};
const homeIcon = '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/png" href="/myhomegroup-logo.png" />
    <meta name="theme-color" content="#E11A20" />
  </head>
  <body class="min-h-screen bg-muted/30 text-foreground antialiased">
    <div class="flex min-h-screen">
      <!-- Desktop sidebar: icon-only rail at md, full at lg -->
      <aside
        class="sticky top-0 hidden h-screen w-16 shrink-0 flex-col border-r border-sidebar-border bg-sidebar text-sidebar-foreground md:flex lg:w-64"
      >
        <!-- Brand -->
        <a
          href="/"
          aria-label="MEDHA by MY HOME GROUP"
          class="flex h-16 items-center gap-2.5 px-3 lg:px-5"
        >
          <span class="inline-flex shrink-0 items-center rounded-md bg-white px-2 py-1 shadow-sm ring-1 ring-black/5">
            <img src="/myhomegroup-logo.png" alt="MY HOME GROUP" width="182" height="105" class="h-7 w-auto" />
          </span>
          <span class="hidden text-[19px] font-extrabold tracking-[0.02em] text-white lg:inline">MEDHA</span>
        </a>

        <!-- Nav -->
        <nav class="mt-2 flex flex-1 flex-col gap-1 px-2 lg:px-3">
          {links.map((l) => (
            <a
              href={l.href}
              data-navguard
              aria-current={active === l.key ? "page" : undefined}
              title={l.label}
              class={`flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors max-md:justify-center md:justify-center lg:justify-start ${
                active === l.key
                  ? "bg-sidebar-primary text-sidebar-primary-foreground"
                  : "text-sidebar-foreground/70 hover:bg-sidebar-accent hover:text-sidebar-foreground"
              }`}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="shrink-0"
                set:html={icons[l.key]}
              />
              <span class="hidden lg:inline">{l.label}</span>
            </a>
          ))}
        </nav>

        <!-- Back to landing -->
        <div class="mt-auto border-t border-sidebar-border px-2 py-3 lg:px-3">
          <a
            href="/"
            data-navguard
            title="Back to home"
            class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-sidebar-foreground/70 transition-colors hover:bg-sidebar-accent hover:text-sidebar-foreground md:justify-center lg:justify-start"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="shrink-0"
              set:html={homeIcon}
            />
            <span class="hidden lg:inline">Back to home</span>
          </a>
        </div>
      </aside>

      <!-- Content column -->
      <div class="flex min-w-0 flex-1 flex-col">
        <!-- Mobile top bar -->
        <header
          class="sticky top-0 z-40 flex h-14 items-center gap-3 border-b border-sidebar-border bg-sidebar px-4 text-sidebar-foreground md:hidden"
        >
          <MobileNav client:load active={active} links={links} />
          <a href="/" class="flex items-center gap-2.5" aria-label="MEDHA by MY HOME GROUP">
            <span class="inline-flex items-center rounded-md bg-white px-2 py-1 shadow-sm ring-1 ring-black/5">
              <img src="/myhomegroup-logo.png" alt="MY HOME GROUP" width="182" height="105" class="h-6 w-auto" />
            </span>
            <span class="text-[17px] font-extrabold tracking-[0.02em] text-white">MEDHA</span>
          </a>
        </header>

        <main class="mx-auto w-full max-w-[1536px] px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
          <slot />
        </main>
      </div>
    </div>

    <!-- Navigation guard: if a tool reports in-progress work (window.__MEDHA_BUSY__),
         confirm before following a sidebar link. Work is also saved to sessionStorage,
         so the warning is a courtesy, not the safety net. -->
    <script is:inline>
      document.addEventListener("click", (e) => {
        const a = e.target.closest("a[data-navguard]");
        if (!a || !window.__MEDHA_BUSY__) return;
        const ok = window.confirm(
          "This tool is still working. Your progress is saved and will be restored when you come back. Leave this page now?"
        );
        if (!ok) e.preventDefault();
      }, true);
    </script>
  </body>
</html>

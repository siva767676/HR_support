# Your GPU host (Ollama, OpenAI-compatible API)
VLLM_BASE_URL=http://172.20.7.22:11434
VLLM_MODEL=gemma4:31b
VLLM_API_KEY=EMPTY

# ----- Optional: embedding model for semantic resume scoring -----
EMBEDDING_MODEL=all-MiniLM-L6-v2


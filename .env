# --- vLLM (Ollama OpenAI-compatible endpoint on the GPU host) ---
# Remote LAN host, reachable from both native runs and the Docker container
# (the pinned docker subnet keeps 172.20.7.22 routable from inside the container).
VLLM_BASE_URL=http://172.20.7.22:11434
VLLM_MODEL=gemma4:31b
VLLM_API_KEY=EMPTY
VLLM_TEMPERATURE=0.3
VLLM_MAX_TOKENS=20000
VLLM_HTTP_TIMEOUT_S=300

# ----- Optional: embedding model for semantic resume scoring -----
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ----- Folder whose subfolders/files are the selectable Job Descriptions -----
# (used for native runs; docker-compose overrides this with its /jds mount)
JD_DIR=D:\OneDrive - MY HOME CONSTRUCTIONS (P) LTD\Desktop\JD

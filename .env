# --- vLLM (Ollama OpenAI-compatible endpoint on the GPU host) ---
# Remote LAN host, reachable from both native runs and the Docker container
# (the pinned docker subnet keeps 172.20.7.22 routable from inside the container).
VLLM_BASE_URL=http://172.20.7.22:8000/v1
VLLM_MODEL=gemma4-31b
VLLM_API_KEY=EMPTY
VLLM_TEMPERATURE=0.3
VLLM_MAX_TOKENS=20000
VLLM_HTTP_TIMEOUT_S=300

# ----- Latency tuning -----
# Resumes truncated at 4000 chars — covers 99% of 1-3 page CVs; was 10000
MAX_DOC_CHARS=4000
# Evaluation JSON rarely exceeds 1200 tokens; was 3000 (saves ~25s per call)
MAX_OUTPUT_TOKENS=1200
# Ollama serializes requests so batching just creates huge prompts that fail
# and fall back to individual calls — set to 1 to avoid that trap
BATCH_EVAL_SIZE=1
# Evaluate only the top 10 (embeddings shortlist is accurate enough); was 20
TOP_K=10
# 1 retry is enough — 3 retries × 8s backoff = 24s wasted per bad response
LLM_MAX_RETRIES=1

# ----- Optional: embedding model for semantic resume scoring -----
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ----- Folder whose subfolders/files are the selectable Job Descriptions -----
# (used for native runs; docker-compose overrides this with its /jds mount)
JD_DIR=D:\OneDrive - MY HOME CONSTRUCTIONS (P) LTD\Desktop\JD
